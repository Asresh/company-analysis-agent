BRIGHTDATA_API_TOKEN=your_api_token_here
# Optional — defaults to the zone @brightdata/mcp provisions.
# Override only if your BrightData dashboard uses a different zone name.
BRIGHTDATA_UNLOCKER_ZONE=mcp_unlocker
BRIGHTDATA_SERP_ZONE=mcp_unlocker

# TokenRouter — OpenAI-compatible LLM gateway
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
TOKENROUTER_API_KEY=your_tokenrouter_api_key_here
# Optional — defaults to anthropic/claude-sonnet-4.6
TOKENROUTER_MODEL=anthropic/claude-sonnet-4.6
